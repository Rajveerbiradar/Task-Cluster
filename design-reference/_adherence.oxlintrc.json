{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/planner/**",
              "ui_kits/taskcluster/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:General Sans))/i]",
        "message": "Font not provided by the design system. Available: General Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:read-only|planning|info)$/]",
        "message": "<Banner> variant must be one of 'read-only' | 'planning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|onModeChange|style|key|ref|className|style|children)$/]",
        "message": "<BottomBar> doesn't accept that prop. Declared props: mode, onModeChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|iconLeft|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, iconLeft."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|size|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, disabled, size, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextMenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|danger|disabled|divider|shortcut|submenu|onClick|key|ref|className|style|children)$/]",
        "message": "<ContextMenuItem> doesn't accept that prop. Declared props: icon, label, danger, disabled, divider, shortcut, submenu, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateStripDay'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|weekday|date|placeholder|key|ref|className|style|children)$/]",
        "message": "<DateStripDay> doesn't accept that prop. Declared props: key, weekday, date, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|stroke|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, stroke, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|size|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, active, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='ParentSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|pinned|onMenu|tint|children|style|key|ref|className|style|children)$/]",
        "message": "<ParentSection> doesn't accept that prop. Declared props: title, count, pinned, onMenu, tint, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|done|total|status|time|expanded|pinned|onToggle|onMenu|children|style|key|ref|className|style|children)$/]",
        "message": "<SectionCard> doesn't accept that prop. Declared props: title, done, total, status, time, expanded, pinned, onToggle, onMenu, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Snackbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|action|onAction|style|key|ref|className|style|children)$/]",
        "message": "<Snackbar> doesn't accept that prop. Declared props: children, action, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|checked|status|time|divider|onToggle|onMenu|style|key|ref|className|style|children)$/]",
        "message": "<TaskRow> doesn't accept that prop. Declared props: title, description, checked, status, time, divider, onToggle, onMenu, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|placeholder|multiline|rows|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, placeholder, multiline, rows, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimeInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|value|time|days|hours|onModeChange|onValueChange|onTimeChange|onDaysChange|onHoursChange|label|style|key|ref|className|style|children)$/]",
        "message": "<TimeInput> doesn't accept that prop. Declared props: mode, value, time, days, hours, onModeChange, onValueChange, onTimeChange, onDaysChange, onHoursChange, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|style|key|ref|className|style|children)$/]",
        "message": "<TimePill> doesn't accept that prop. Declared props: status, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children, icon, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
